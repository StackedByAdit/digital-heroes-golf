# Supabase — copy from Project Settings → API Keys in the dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# anon JWT (eyJ...) OR publishable key (sb_publishable_...) — NOT the REST URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: service_role JWT or sb_secret_... key (required for signup without confirmation emails)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Database setup (`npm run db:setup`)
# Prefer pasting the Session pooler URI from Supabase → Project Settings → Database
DATABASE_URL=
# Or set password + optional region (auto-detected if omitted)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=
SUPABASE_POOLER_PREFIX=aws-1

# Stripe
# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Created by `npm run stripe:setup` (monthly £10, yearly £100)
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=
