# Supabase - copy from Project Settings > API in the dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# anon JWT (eyJ...) OR publishable key (sb_publishable_...) - NOT the REST URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: service_role JWT or sb_secret_... key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Database setup (`npm run db:setup`)
# Prefer pasting the Session pooler URI from Supabase > Project Settings > Database
DATABASE_URL=
# Or set password + optional region (auto-detected if omitted)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=
SUPABASE_POOLER_PREFIX=aws-1

# Stripe - https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Created manually in Stripe or by `npm run stripe:setup` (monthly GBP 10, yearly GBP 100)
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=
EMAIL_FROM="Digital Heroes <onboarding@resend.dev>"
